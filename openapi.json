{"openapi": "3.1.0", "info": {"title": "FastAPI", "version": "0.1.0"}, "paths": {"/auth/login": {"get": {"tags": ["Authentication"], "summary": "Login", "description": "Initiates the OAuth 2.0 login flow.\n\nGenerates a state parameter for CSRF protection, sets it in a cookie,\nand redirects the user to the configured authentication provider.\n\nArgs:\n    request: The FastAPI request object.\n\nReturns:\n    A RedirectResponse to the provider's login URL.", "operationId": "login_auth_login_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/auth/callback": {"get": {"tags": ["Authentication"], "summary": "Callback", "description": "Handles the OAuth 2.0 callback from the provider.\n\nVerifies the CSRF state, exchanges the authorization code for tokens,\ncreates a user session, and sets a signed session cookie.\n\nArgs:\n    request: The FastAPI request object containing query parameters.\n\nReturns:\n    A RedirectResponse to the root URL upon success.\n\nRaises:\n    HTTPException: If the code is missing, state is invalid, or authentication fails.", "operationId": "callback_auth_callback_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/auth/me": {"get": {"tags": ["Authentication"], "summary": "Get Me", "description": "Retrieves the current authenticated user's profile and state.\n\nArgs:\n    request: The FastAPI request object.\n\nReturns:\n    A dictionary containing authentication status, user profile, and Logenesis state.\n    Returns 401 status if not authenticated.", "operationId": "get_me_auth_me_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/auth/logout": {"post": {"tags": ["Authentication"], "summary": "Logout", "description": "Logs out the user.\n\nClears the session cookie.\n\nReturns:\n    A JSONResponse indicating success.", "operationId": "logout_auth_logout_post", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/v1/session": {"post": {"tags": ["aetherium"], "summary": "Create Session", "description": "Control Plane: Establish a conscious connection.\nRequires:\n1. Valid .abe Contract (Identity)\n2. Valid Access Key (Permission)", "operationId": "create_session_v1_session_post", "requestBody": {"content": {"application/json": {"schema": {"additionalProperties": true, "type": "object", "title": "Body"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/entropy/submit": {"post": {"tags": ["entropy-economy"], "summary": "Submit Entropy Packet", "operationId": "submit_entropy_packet_api_v1_entropy_submit_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/EntropySubmitRequest"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EntropySubmitResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/sw.js": {"get": {"summary": "Get Sw", "description": "Serve the frontend service worker JavaScript file.\n\nReturns:\n    FileResponse: Response streaming the `src/frontend/public/sw.js` file with `application/javascript` media type.", "operationId": "get_sw_sw_js_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/manifest.json": {"get": {"summary": "Get Manifest", "description": "Serve the web application's manifest.json file.\n\nReturns:\n    FileResponse: A response streaming the `src/frontend/public/manifest.json` file with media type `application/json`.", "operationId": "get_manifest_manifest_json_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/dashboard": {"get": {"summary": "Dashboard", "description": "Serve the dashboard HTML page.\n\nReturns:\n    FileResponse: A response that serves the dashboard.html file from the frontend directory.", "operationId": "dashboard_dashboard_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/public": {"get": {"summary": "Public Gateway", "description": "Serve the public gateway HTML page.\n\nReturns:\n    FileResponse: Response that serves the `src/frontend/aether_public.html` file from the project base directory.", "operationId": "public_gateway_public_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/overseer": {"get": {"summary": "Overseer Gateway", "description": "Serve the Aether overseer HTML page.\n\nReturns:\n    FileResponse: Response serving the `aether_overseer.html` file from the project's frontend directory.", "operationId": "overseer_gateway_overseer_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}}, "components": {"schemas": {"ActualAction": {"properties": {"type": {"type": "string", "title": "Type"}, "content_hash": {"type": "string", "title": "Content Hash"}, "input_method": {"type": "string", "title": "Input Method"}, "micro_metrics": {"$ref": "#/components/schemas/MicroMetrics"}, "content_preview": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Content Preview", "description": "Optional short input preview used for semantic/noise validation."}}, "type": "object", "required": ["type", "content_hash", "input_method"], "title": "ActualAction"}, "EntropyAssessment": {"properties": {"packet_id": {"type": "string", "format": "uuid", "title": "Packet Id"}, "qou_score": {"type": "number", "maximum": 1.0, "minimum": 0.0, "title": "Qou Score"}, "semantic_weight": {"type": "number", "maximum": 1.0, "minimum": 0.0, "title": "Semantic Weight"}, "safety_weight": {"type": "number", "maximum": 1.0, "minimum": 0.0, "title": "Safety Weight"}, "surprise_factor": {"type": "number", "maximum": 1.0, "minimum": 0.0, "title": "Surprise Factor"}, "reward_amount": {"type": "integer", "minimum": 0.0, "title": "Reward Amount"}, "meter_state": {"$ref": "#/components/schemas/MeterState"}, "preserve": {"type": "boolean", "title": "Preserve", "default": false}, "trigger_model_update": {"type": "boolean", "title": "Trigger Model Update", "default": false}, "anti_gaming_flag": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Anti Gaming Flag"}}, "type": "object", "required": ["packet_id", "qou_score", "semantic_weight", "safety_weight", "surprise_factor", "reward_amount", "meter_state"], "title": "EntropyAssessment"}, "EntropyPacket": {"properties": {"packet_id": {"type": "string", "format": "uuid", "title": "Packet Id"}, "timestamp": {"type": "string", "format": "date-time", "title": "Timestamp"}, "user_context": {"$ref": "#/components/schemas/UserContext"}, "prediction_snapshot": {"$ref": "#/components/schemas/PredictionSnapshot"}, "actual_action": {"$ref": "#/components/schemas/ActualAction"}}, "type": "object", "required": ["packet_id", "timestamp", "user_context", "prediction_snapshot", "actual_action"], "title": "EntropyPacket"}, "EntropySubmitRequest": {"properties": {"user_id": {"type": "string", "format": "uuid", "title": "User Id"}, "packet": {"$ref": "#/components/schemas/EntropyPacket"}}, "type": "object", "required": ["user_id", "packet"], "title": "EntropySubmitRequest"}, "EntropySubmitResponse": {"properties": {"assessment": {"$ref": "#/components/schemas/EntropyAssessment"}, "ledger_entry_id": {"type": "string", "format": "uuid", "title": "Ledger Entry Id"}, "artifact_ref": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Artifact Ref"}, "hash_chain_head": {"type": "string", "title": "Hash Chain Head"}}, "type": "object", "required": ["assessment", "ledger_entry_id", "hash_chain_head"], "title": "EntropySubmitResponse"}, "HTTPValidationError": {"properties": {"detail": {"items": {"$ref": "#/components/schemas/ValidationError"}, "type": "array", "title": "Detail"}}, "type": "object", "title": "HTTPValidationError"}, "MeterState": {"type": "string", "enum": ["predictable", "divergent", "chaotic_genius"], "title": "MeterState"}, "MicroMetrics": {"properties": {"typing_variance": {"type": "number", "maximum": 1.0, "minimum": 0.0, "title": "Typing Variance", "default": 0.0}, "hesitation_pauses": {"type": "integer", "minimum": 0.0, "title": "Hesitation Pauses", "default": 0}, "mouse_jitter": {"anyOf": [{"type": "number", "maximum": 1.0, "minimum": 0.0}, {"type": "null"}], "title": "Mouse Jitter"}, "voice_tone_variance": {"anyOf": [{"type": "number", "maximum": 1.0, "minimum": 0.0}, {"type": "null"}], "title": "Voice Tone Variance"}}, "type": "object", "title": "MicroMetrics"}, "PredictionSnapshot": {"properties": {"model_version": {"type": "string", "title": "Model Version"}, "predicted_action": {"type": "string", "title": "Predicted Action"}, "confidence_score": {"type": "number", "maximum": 1.0, "minimum": 0.0, "title": "Confidence Score"}}, "type": "object", "required": ["model_version", "predicted_action", "confidence_score"], "title": "PredictionSnapshot"}, "UserContext": {"properties": {"current_screen": {"type": "string", "title": "Current Screen"}, "previous_actions": {"items": {"type": "string"}, "type": "array", "title": "Previous Actions"}}, "type": "object", "required": ["current_screen"], "title": "UserContext"}, "ValidationError": {"properties": {"loc": {"items": {"anyOf": [{"type": "string"}, {"type": "integer"}]}, "type": "array", "title": "Location"}, "msg": {"type": "string", "title": "Message"}, "type": {"type": "string", "title": "Error Type"}, "input": {"title": "Input"}, "ctx": {"type": "object", "title": "Context"}}, "type": "object", "required": ["loc", "msg", "type"], "title": "ValidationError"}}}}
